# Netlify environment variables (set these in Netlify UI, not committed secrets)

## S3 / AWS
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Optional: prefix for all uploaded objects in the bucket
S3_PREFIX=qrf

# Optional: local S3-compatible storage (e.g. Docker Compose MinIO)
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_FORCE_PATH_STYLE=true

## Postgres
# Example: postgres://user:password@host:5432/dbname?sslmode=require
POSTGRES_URL=

## Admin dashboard Basic Auth
ADMIN_USER=
ADMIN_PASS=

## Consent PDF signature placement (optional)
# These values control where the signature image is stamped onto pdf/consent_form.pdf
# Units are PDF points. Defaults are used if left blank.
CONSENT_SIG_PAGE=0
CONSENT_SIG_X=80
CONSENT_SIG_Y=120
CONSENT_SIG_W=220
CONSENT_SIG_H=80

# --- Docker Compose (local) ---
# After: docker compose up -d
# POSTGRES_URL=postgres://qrf:qrf_dev_secret@localhost:55432/quran_recording
# S3_BUCKET=quran-recording-local
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadminsecret
# AWS_REGION=us-east-1
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_FORCE_PATH_STYLE=true
# MinIO console: http://localhost:9001

